# 네이버 뉴스 검색 API (M1 — 수집)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# LLM (M2 extract / M3 propose / judge) — M1에서는 불필요
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# OpenDART (M4 enrich) — M1에서는 불필요
DART_API_KEY=

# 알림 (M7 notify) — 선택. config/settings.yaml 의 notify 채널을 켰을 때만 사용.
# 텔레그램: @BotFather 로 봇 생성→토큰, 봇과 대화 시작 후 chat_id 확인.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 이메일(SMTP): 예) Gmail 은 host=smtp.gmail.com port=587, 앱 비밀번호 사용.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
